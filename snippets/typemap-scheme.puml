@startuml
skinparam backgroundColor #FEFEFE
scale 3

skinparam participant {
  BackgroundColor #1E8BB3
  FontColor white
  FontStyle bold
  BorderColor #000000
}

skinparam sequence {
  ArrowColor #000000
}

participant "C Function\nParameters" as CParams
participant "Typemap\n(INPUT)" as TypemapIn
participant "XS Code" as XSCode
participant "Typemap\n(OUTPUT)" as TypemapOut
participant "Perl Values" as PerlVals

CParams -> TypemapIn : Perl arg → C var
TypemapIn -> XSCode : pass C values
XSCode -> TypemapOut : return C result
TypemapOut -> PerlVals : C value → Perl scalar

@enduml

